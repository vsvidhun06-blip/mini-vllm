{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["mini-vllm", "inference"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "mini-vLLM — Inference Observability",
  "uid": "mini-vllm",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "title": "TTFT — Time To First Token (P50 / P95 / P99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Latency from request admission to its first emitted token. The headline single-request responsiveness metric; rises when prompts queue behind long prefills or the cache saturates.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(ttft_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(ttft_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(ttft_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 2,
      "title": "TPOT — Time Per Output Token (P50 / P95 / P99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Inter-token latency during decode — the streaming smoothness a user feels. Dominated by per-step kernel-launch overhead; this is the metric CUDA graphs target.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(tpot_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(tpot_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(tpot_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Queue Depth — requests waiting for admission",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Requests queued but not yet in the active batch. Persistently above zero means offered load exceeds batch/pool capacity — the leading indicator of rising TTFT.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mini_vllm_queue_depth",
          "legendFormat": "waiting"
        }
      ]
    },
    {
      "id": 4,
      "title": "KV Cache Utilisation",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Percentage of KV-cache blocks in use. As this nears 100% the scheduler can no longer admit requests and may preempt — the primary saturation signal for a paged-attention engine.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mini_vllm_cache_utilisation",
          "legendFormat": "utilisation"
        }
      ]
    },
    {
      "id": 5,
      "title": "Requests / sec (completed)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Completed-request throughput, rate of requests_total{status=\"finished\"} over 1m.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(requests_total{status=\"finished\"}[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 6,
      "title": "Decode Batch Size (histogram over time)",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Distribution of how many requests share each batched decode step. Higher, denser batches = better GPU utilisation on the bandwidth-bound decode.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": { "mode": "scheme", "scheme": "Oranges", "steps": 64 },
        "yAxis": { "unit": "short", "decimals": 0 },
        "legend": { "show": true },
        "tooltip": { "show": true, "yHistogram": true }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(mini_vllm_batch_size_bucket[1m])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 7,
      "title": "CUDA Graph Hit Rate",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Share of batched-decode forwards served by a captured CUDA graph vs eager fallback. 0% on CPU or before any capture (the honest eager-path picture); higher = more launch overhead eliminated.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(mini_vllm_cuda_graph_hits_total{outcome=\"hit\"}[5m])) / clamp_min(sum(rate(mini_vllm_cuda_graph_hits_total[5m])), 1)",
          "legendFormat": "hit rate"
        }
      ]
    },
    {
      "id": 8,
      "title": "Bottleneck Over Time",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Which scheduler phase dominates each step, from the StepProfiler's rolling window. The active phase reads 1; watching the lanes light up shows the bottleneck shifting (e.g. prefill -> decode under load) — the signal the auto-tuner acts on.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "custom": { "fillOpacity": 80, "lineWidth": 0 },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "idle", "color": "transparent", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "active", "color": "orange", "index": 1 } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "showValue": "never",
        "rowHeight": 0.9,
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mini_vllm_bottleneck_type",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Bottleneck Distribution",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Share of the selected time range each phase spent as the bottleneck (avg_over_time of the active gauge). A balanced engine spreads the slices; one dominant slice is where tuning effort pays off.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "hideFrom": { "tooltip": false, "viz": false, "legend": false } },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "pieType": "pie",
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent"] },
        "tooltip": { "mode": "single", "sort": "desc" },
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg_over_time(mini_vllm_bottleneck_type[$__range])",
          "legendFormat": "{{type}}",
          "instant": true
        }
      ]
    }
  ]
}
